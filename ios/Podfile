# ios/Podfile
platform :ios, '13.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Flutter pod helper
require File.join(File.dirname(`cd #{Dir.pwd} && pwd`), 'Flutter', 'podhelper.rb')

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  
  # Explicitly add Firebase pods with modular headers disabled
  pod 'Firebase/CoreOnly', '~> 10.23.0', :modular_headers => false
  pod 'Firebase/Messaging', '~> 10.23.0', :modular_headers => false
  pod 'Firebase/Auth', '~> 10.23.0', :modular_headers => false
  
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      
      # For Firebase
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'FIRFirestore_VERSION=10.23.0',
        'FIREBASE_USE_MODULAR_FRAMEWORK=1'
      ]
    end
    
    # Specific fix for Firebase targets
    if target.name.include?('Firebase')
      target.build_configurations.each do |config|
        config.build_settings['DEFINES_MODULE'] = 'YES'
      end
    end
  end
end