platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Use frameworks and modular headers (required by most Flutter plugins)
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter will generate Podfile dependencies automatically
  flutter_application_path = File.expand_path('..', __dir__)
  eval(File.read(File.join(flutter_application_path, 'Flutter', 'podhelper.rb'))) if File.exist?(File.join(flutter_application_path, 'Flutter', 'podhelper.rb'))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
    end
  end
end
