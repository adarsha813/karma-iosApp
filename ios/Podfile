platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# First, load the Flutter podhelper.rb from your Flutter SDK
flutter_podfile_path = File.expand_path(File.join('..', 'packages', 'flutter_tools', 'bin', 'podhelper.rb'), ENV['FLUTTER_ROOT'])
require flutter_podfile_path

# Get flutter_application_path from environment variable
flutter_application_path = ENV['FLUTTER_APPLICATION_PATH'] || File.expand_path('..', __dir__)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Use the correct method name for your Flutter version
  install_all_flutter_pods(flutter_application_path)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      # Additional build settings if needed
    end
  end
end