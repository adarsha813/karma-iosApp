platform :ios, '13.0'

use_frameworks!
use_modular_headers!

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# ✅ This automatically uses the Flutter SDK from CI (Codemagic sets FLUTTER_ROOT)
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), ENV['FLUTTER_ROOT'])

target 'Runner' do
  flutter_application_path = File.expand_path('..', __dir__)
  install_all_flutter_pods(flutter_application_path)
end
